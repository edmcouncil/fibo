		<rdfs:label>ACTUS dictionary term - CT - UMP</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">6</fibo-actus-act:hasOptionSequenceNumber>
