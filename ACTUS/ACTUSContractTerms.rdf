		<cmns-dsg:hasDescription>An agreement of swapping two legs such as fixed against variable or currency 1 against currency 2 etc.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>SWAPS</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Swap</cmns-dsg:hasTextualName>
