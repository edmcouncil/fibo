		<cmns-dsg:hasDescription>Different types of options on buying an underlying instrument at a fixed price in the future.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>OPTNS</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Option</cmns-dsg:hasTextualName>
