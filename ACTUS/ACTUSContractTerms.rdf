		<cmns-dsg:hasDescription>Represents stocks/shares/equity.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>STK</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Stock</cmns-dsg:hasTextualName>
