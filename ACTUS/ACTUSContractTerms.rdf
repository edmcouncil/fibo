		<dct:source rdf:datatype="&xsd;anyURI">https://www.actusfrf.org</dct:source>
		<owl:imports rdf:resource="https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSTaxonomy/"/>
		<owl:imports rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/AnnotationVocabulary/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Classifiers/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/CodesAndCodeSets/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Collections/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Designators/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Identifiers/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/PartiesAndSituations/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/QuantitiesAndUnits/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/TextDatatype/"/>
		<owl:versionIRI rdf:resource="https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/"/>
		<fibo-fnd-utl-av:hasMaturityLevel rdf:resource="&fibo-fnd-utl-av;Provisional"/>
		<cmns-av:copyright>Copyright (c) 2026 ACTUS Financial Research Foundation</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2026 EDM Council, Inc.</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2026 Object Management Group, Inc.</cmns-av:copyright>
	</owl:Ontology>
	
	<owl:Class rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier">
		<rdfs:subClassOf rdf:resource="&cmns-cls;Classifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;isDefinedIn"/>
				<owl:hasValue rdf:resource="&fibo-actus-act;AlgorithmicContractTypesDataDictionary"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-cls;classifies"/>
				<owl:someValuesFrom rdf:resource="&cmns-pts;Role"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>ACTUS contract role classifier</rdfs:label>
		<skos:definition>classifier for a various roles that are relevant to a particular contract principal</skos:definition>
	</owl:Class>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-BUY">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - BUY</rdfs:label>
		<cmns-dsg:hasDescription>contract role of BUY, indicating that the legal person identified as the contract principal (creator) plays the role of buyer with respect to the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BUY</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Buyer</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-CNO">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - CNO</rdfs:label>
		<cmns-dsg:hasDescription>contract role of CNO, indicating that settlement of the contract involves close-out netting with respect to the legal person identified as the contract principal (creator)</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CNO</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Close Out Netting</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-COL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - COL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of COL, indicating that the contract is treated as collateral with respect to the legal person identified as the contract principal (creator)</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>COL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Collateral</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-GUA">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - GUA</rdfs:label>
		<cmns-dsg:hasDescription>contract role of GUA, indicating that the legal person identified as the contract principal (creator) plays the role of guarantor with respect to the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>GUA</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Guarantor</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-LG">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - LG</rdfs:label>
		<cmns-dsg:hasDescription>contract role of LG, indicating that the legal person identified as the contract principal (creator) has a long position in the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>LG</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Long Position</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-OBL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - OBL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of OBL, indicating that the legal person identified as the contract principal (creator) plays the role of obligor with respect to the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>OBL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Obligor</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-PFL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - PFL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of PFL, indicating that the legal person identified as the contract principal (creator) plays the role of payer on the first leg (leg 1) of the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>PFL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Pay First/Fixed Leg</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-RFL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - RFL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of RFL, indicating that the legal person identified as the contract principal (creator) plays the role of receiver on the first leg (leg 1) of the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>RFL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Receive First/Fixed Leg</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-RPA">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - RPA</rdfs:label>
		<cmns-dsg:hasDescription>contract role of RPA, indicating that the contract is considered an asset of the legal person identified as the contract principal (creator)</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>RPA</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Real Position Asset</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-RPL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - RPL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of RPL, indicating that the contract is considered a liability of the legal person identified as the contract principal (creator)</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>RPL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Real Position Liability</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-SEL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - SEL</rdfs:label>
		<cmns-dsg:hasDescription>contract role of SEL, indicating that the legal person identified as the contract principal (creator) plays the role of seller with respect to the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>SEL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Seller</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractRoleClassifier-ST">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractRoleClassifier"/>
		<rdfs:label>ACTUS contract role classifier - ST</rdfs:label>
		<cmns-dsg:hasDescription>contract role of ST, indicating that the legal person identified as the contract principal (creator) has a short position in the contract</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ST</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Short Position</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:Class rdf:about="&fibo-actus-act;ACTUSContractTerm">
		<rdfs:subClassOf rdf:resource="&cmns-cds;CodeElement"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-col;isMemberOf"/>
				<owl:hasValue rdf:resource="&fibo-actus-act;AlgorithmicContractTypesDataDictionary"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;isDefinedIn"/>
				<owl:hasValue rdf:resource="&fibo-actus-act;AlgorithmicContractTypesDataDictionary"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&fibo-actus-act;hasParameterName"/>
				<owl:onDataRange rdf:resource="&xsd;string"/>
				<owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-cls;characterizes"/>
				<owl:someValuesFrom rdf:resource="&fibo-actus-acv;ACTUSContractType"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-cls;isClassifiedBy"/>
				<owl:someValuesFrom rdf:resource="&fibo-actus-act;ACTUSContractTermGroup"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasTag"/>
				<owl:someValuesFrom rdf:resource="&xsd;string"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasTextualName"/>
				<owl:someValuesFrom rdf:resource="&xsd;string"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>ACTUS contract term</rdfs:label>
		<skos:definition>code denoting a term describing an aspect of one or more ACTUS contract type(s)</skos:definition>
	</owl:Class>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-AMD">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - AMD</rdfs:label>
		<fibo-actus-act:hasParameterName>amortizationDate</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>This Date is used to calculate the annuity amounts for ANN and ANX NGX CT&apos;s. Needs only to be set in case where the contract balloon at MD and MD is less than AD.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>AMD</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Amortization Date</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARFIXVAR">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARFIXVAR</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayFixedVariable</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-RateReset"/>
		<cmns-dsg:hasDescription>For array-type rate reset schedules, this attributes defines the meaning of ARRATE.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARRRCL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Fixed Variable</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARINCDEC">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARINCDEC</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayIncreaseDecrease</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>Indicates whether a certain PRNXT element in ARPRNX increases the principal (NT) or decreases it.

Applies only for ANX, NAX, LAX Maturity CTs. For all other Maturity CTs the first principal payment is always in the opposite direction of all other (following) payments.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARRRCL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Increase Decrease</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARIPANXi">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARIPANXi</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleAnchorDateOfInterestPayment</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Interest"/>
		<cmns-dsg:hasDescription>Same like IPANX but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARIPANXi</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Anchor Date Of Interest Payment</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARIPCLi">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARIPCLi</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleOfInterestPayment</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Interest"/>
		<cmns-dsg:hasDescription>Same like IPCL but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARIPCLi</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Of Interest Payment</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARPRANXj">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARPRANXj</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleAnchorDateOfPrincipalRedemption</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>Same like PRANX but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARIPANXj</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Anchor Date Of Principal Redemption</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARPRCLj">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARPRCLj</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleOfPrincipalRedemption</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>Same like PRCL but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARPRCLj</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Of Principal Redemption</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARPRNXTj">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARPRNXTj</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayNextPrincipalRedemptionPayment</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>Same like PRNXT but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARPRNXTj</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Next Principal Redemption Payment</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARRATE">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARRATE</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayRate</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-RateReset"/>
		<cmns-dsg:hasDescription>For array-type rate reset schedules, this attribute represents either an interest rate (corresponding to IPNR) or a spread (corresponding to RRSP). Which case applies depends on the attribute ARFIXVAR: if ARFIXVAR=FIX then it represents the new IPNR and if ARFIXVAR=VAR then the applicable RRSP.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARRATE</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Rate</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARRRANX">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARRRANX</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleAnchorDateOfRateReset</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-RateReset"/>
		<cmns-dsg:hasDescription>Same like RRANX but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARRRANX</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Anchor Date Of Rate Reset</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-ARRRCL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - ARRRCL</rdfs:label>
		<fibo-actus-act:hasParameterName>arrayCycleOfRateReset</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-RateReset"/>
		<cmns-dsg:hasDescription>Same like RRCL but as array</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ARRRCL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Array Cycle Of Rate Reset</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BCF">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BCF</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryCrossedFlag</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>Initializes the value of Boundary Crossed Flag state variable at statusDate</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BCF</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Crossed Flag</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BDC">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BDC</rdfs:label>
		<fibo-actus-act:hasParameterName>businessDayConvention</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Calendar"/>
		<cmns-dsg:hasDescription>BDC&apos;s are linked to a calendar. Calendars have working and non-working days. A BDC value other than N means that cash flows cannot fall on non-working days, they must be shifted to the next business day (following) or the previous on (preceding).

These two simple rules get refined twofold:

- Following modified (preceding): Same like following (preceding), however if a cash flow gets shifted into a new month, then  it is shifted to preceding (following) business day.

- Shift/calculate (SC) and calculate/shift (CS). Accrual, principal, and possibly other calculations are affected by this choice. In the case of SC first the dates are shifted and after the shift cash flows are calculated. In the case of CS it is the other way round.

Attention: Does not affect non-cyclical dates such as PRD, MD, TD, IPCED since they can be set to the correct date directly.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BDC</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Business Day Convention</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BDR">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BDR</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryDirection</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>Boundary direction specifies the direction of motion in the underlying asset&apos;s price which will be considered a valid crossing of the boundary and trigger the boundary effect changing which, if any, of the boundary legs is  active.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BDR</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Direction</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BEF">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BEF</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryEffect</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>This term specifies which leg - if any-  becomes the active subcontract  when the underlying asset&apos;s price crosses the specified boundary value in the specified direction triggerring a boundary crossing event.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BEF</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Effect</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BLIA">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BLIA</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryLegInitiallyActive</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>Specifies which leg - if any - is the active contract  in effect when the boundary controlled switch contract starts.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BLIA</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Leg Initially Active</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BMANX">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BMANX</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryMonitoringAnchorDate</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>The first Boundary monitoring event occurs on this date</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BMANX</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Monitoring Anchor Date</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BMCL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BMCL</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryMonitoringCycle</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>The frequency with which boundary monitoring events occur. It defines how often the system checks to test whether the  market value of the underlying asset has crossed the boundary in the specified direction triggerring  a boundary crossing event.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BMCL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Monitoring Cycle</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BMED">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BMED</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryMonitoringEndDate</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>Boundary monitoring ends on this date</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BMED</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Monitoring End Date</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-BV">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - BV</rdfs:label>
		<fibo-actus-act:hasParameterName>boundaryValue</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Boundary"/>
		<cmns-dsg:hasDescription>Boundary value in a barrier options contract, when reached, triggers the boundary effect specified e.g. Knock-In or Knock-out</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>BV</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Boundary Value</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CDD">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CDD</rdfs:label>
		<fibo-actus-act:hasParameterName>contractDealDate</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>This date signifies the origination of the contract where an agreement between the customer and the bank has been settled. From this date on, the institution will have a (market) risk position for financial contracts. This is even the case when IED is in future.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CDD</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Contract Deal Date</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CECV">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CECV</rdfs:label>
		<fibo-actus-act:hasParameterName>coverageOfCreditEnhancement</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Counterparty"/>
		<cmns-dsg:hasDescription>Defines which percentage of the exposure is covered</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CECV</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Coverage Of Credit Enhancement</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CEGE">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CEGE</rdfs:label>
		<fibo-actus-act:hasParameterName>guaranteedExposure</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Counterparty"/>
		<cmns-dsg:hasDescription>Defines which value of the exposure is covered:

- NO: Nominal Value

- NI: Nominal plus Interest

- MV: Market Value</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CEGE</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Guaranteed Exposure</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CETC">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CETC</rdfs:label>
		<fibo-actus-act:hasParameterName>creditEventTypeCovered</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Counterparty"/>
		<cmns-dsg:hasDescription>The type of credit events covered e.g. in credit enhancement or credit default swap contracts. Only the defined credit event types may trigger the protection.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CETC</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Credit Event Type Covered</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CID">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CID</rdfs:label>
		<fibo-actus-act:hasParameterName>contractID</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-ContractIdentification"/>
		<cmns-dsg:hasDescription>Unique identifier of a contract.

If the system is used on a single firm level, an internal unique ID can be generated. If used on a national or globally level, a globally unique ID is required.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CID</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Contract Identifier</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CLA">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CLA</rdfs:label>
		<fibo-actus-act:hasParameterName>creditLineAmount</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-NotionalPrincipal"/>
		<cmns-dsg:hasDescription>If defined, gives the total amount that can be drawn from a credit line. The remaining amount that can still be drawn is given by CLA-NT.

For ANN, NAM, the credit line can only be drawn prior to PRANX-1PRCL.

For CRL, the remaining amount that can still be drawn is given by CLA-Sum(NT of attached contracts).</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CLA</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Credit Line Amount</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CLDR">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CLDR</rdfs:label>
		<fibo-actus-act:hasParameterName>calendar</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Calendar"/>
		<cmns-dsg:hasDescription>Calendar defines the non-working days which affect the dates of contract events (CDE&apos;s) in combination with EOMC and BDC. Custom calendars can be added as additional enum options.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CLDR</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Calendar</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CNTRL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CNTRL</rdfs:label>
		<fibo-actus-act:hasParameterName>contractRole</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-ContractIdentification"/>
		<cmns-dsg:hasDescription>CNTRL defines which position the CRID ( the creator of the contract record ) takes in a contract. For example, whether the contract is an asset or liability, a long or short position for the CRID. 

Most contracts are simple on or off balance sheet positions which are assets, liabilities. Such contracts can also play a secondary role as a collateral. 

The attribute is highly significant since it determines the direction of all cash flows. The exact meaning is given with each CT in the ACTUS High Level Specification document.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CNTRL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Contract Role</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CPID">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CPID</rdfs:label>
		<fibo-actus-act:hasParameterName>counterpartyID</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-Counterparty"/>
		<cmns-dsg:hasDescription>CPID identifies the counterparty to the CRID in this contract.

CPID is ideally the official LEI which can be a firm, a government body, even a single person etc. However, this can also refer to a annonymous group in which case this information is not to be disclosed. CPID may also refer to a group taking a joint risk or more generally, CPID is the main counterparty, against which the contract has been settled.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CPID</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Counterparty Identifier</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CRID">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CRID</rdfs:label>
		<fibo-actus-act:hasParameterName>creatorID</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-ContractIdentification"/>
		<cmns-dsg:hasDescription>This identifies the legal entity creating the contract record. The counterparty of the contract is tracked in CPID.

CRID is ideally the official LEI which can be a firm, a government body, even a single person etc. However, this can also refer to a annonymous group in which case this information is not to be disclosed. CRID may also refer to a group taking a joint risk.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CRID</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Creator Identifier</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT</rdfs:label>
		<fibo-actus-act:hasParameterName>contractType</fibo-actus-act:hasParameterName>
		<cmns-cls:isClassifiedBy rdf:resource="&fibo-actus-act;ACTUSContractTermGroup-ContractIdentification"/>
		<cmns-dsg:hasDescription>The ContractType is the most important information. It defines the cash flow generating pattern of a contract. The ContractType information in combination with a given state of the risk factors will produce a deterministic sequence of cash flows which are the basis of any financial analysis.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CT</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Contract Type</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT-ANN">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT - ANN</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">1</fibo-actus-act:hasOptionSequenceNumber>
		<fibo-actus-act:hasParameterName>annuity</fibo-actus-act:hasParameterName>
		<cmns-col:isMemberOf rdf:resource="&fibo-actus-act;ACTUSContractTerm-CT"/>
		<cmns-dsg:denotes rdf:resource="&fibo-actus-acv;ACTUSContractType-Annuity"/>
		<cmns-dsg:hasDescription>Lending agreements with fixed periodic payments consisting of an interest and principal portion. The periodic payments are adjusted for variable rate instruments such that maturity remains fixed.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>ANN</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Annuity</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT-CAPFL">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT - CAPFL</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">13</fibo-actus-act:hasOptionSequenceNumber>
		<fibo-actus-act:hasParameterName>capFloor</fibo-actus-act:hasParameterName>
		<cmns-col:isMemberOf rdf:resource="&fibo-actus-act;ACTUSContractTerm-CT"/>
		<cmns-dsg:denotes rdf:resource="&fibo-actus-acv;ACTUSContractType-CapFloorOption"/>
		<cmns-dsg:hasDescription>An agreement of paying the differential (cap or floor) of a reference rate versus a fixed rate.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CAPFL</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Cap and Floor</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT-CEC">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT - CEC</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">17</fibo-actus-act:hasOptionSequenceNumber>
		<fibo-actus-act:hasParameterName>creditEnhancementCollateral</fibo-actus-act:hasParameterName>
		<cmns-col:isMemberOf rdf:resource="&fibo-actus-act;ACTUSContractTerm-CT"/>
		<cmns-dsg:denotes rdf:resource="&fibo-actus-acv;ACTUSContractType-Collateral"/>
		<cmns-dsg:hasDescription>A collateral securing the scheduled payment obligations of an underlying instrument</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CEC</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Credit Enhancement Collateral</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT-CEG">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT - CEG</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">16</fibo-actus-act:hasOptionSequenceNumber>
		<fibo-actus-act:hasParameterName>creditEnhancementGuarantee</fibo-actus-act:hasParameterName>
		<cmns-col:isMemberOf rdf:resource="&fibo-actus-act;ACTUSContractTerm-CT"/>
		<cmns-dsg:denotes rdf:resource="&fibo-actus-acv;ACTUSContractType-Guarantee"/>
		<cmns-dsg:hasDescription>A guarantee / letter of credit by a third party on the scheduled payment obligations of an underlying instrument</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CEG</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Credit Enhancement Guarantee</cmns-dsg:hasTextualName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-act;ACTUSContractTerm-CT-CLM">
		<rdf:type rdf:resource="&fibo-actus-act;ACTUSContractTerm"/>
		<rdfs:label>ACTUS dictionary term - CT - CLM</rdfs:label>
		<fibo-actus-act:hasOptionSequenceNumber rdf:datatype="&xsd;nonNegativeInteger">5</fibo-actus-act:hasOptionSequenceNumber>
		<fibo-actus-act:hasParameterName>callMoney</fibo-actus-act:hasParameterName>
		<cmns-col:isMemberOf rdf:resource="&fibo-actus-act;ACTUSContractTerm-CT"/>
		<cmns-dsg:denotes rdf:resource="&fibo-actus-acv;ACTUSContractType-CallMoney"/>
		<cmns-dsg:hasDescription>Loans that are rolled over as long as they are not called. Once called it has to be paid back after the stipulated notice period.</cmns-dsg:hasDescription>
		<cmns-dsg:hasTag>CLM</cmns-dsg:hasTag>
		<cmns-dsg:hasTextualName>Call Money</cmns-dsg:hasTextualName>
