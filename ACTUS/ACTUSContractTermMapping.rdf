	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTermMapping/">
		<rdfs:label>ACTUS Contract Term Mapping</rdfs:label>
		<dct:abstract>This ontology represents a mapping from ACTUS contract terms that comprise the ACTUS data dictionary as a controlled vocabulary the corresponding concept(s) in FIBO, providing the relevant semantics and enabling integration.</dct:abstract>
