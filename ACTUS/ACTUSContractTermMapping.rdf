			</owl:Restriction>
		</rdf:type>
		<skos:editorialNote>Rather than classifying the collateral agreement, should this classify any debt instrument that is collateralized?</skos:editorialNote>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-acv;ACTUSContractType-Commodity">
