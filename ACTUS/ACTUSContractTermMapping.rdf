	<owl:NamedIndividual rdf:about="&fibo-actus-acv;ACTUSContractType-ConvertibleNote">
		<rdf:type>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-doc;refersTo"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Restriction>
								<owl:onProperty rdf:resource="&fibo-sec-dbt-dbti;hasCallFeature"/>
								<owl:someValuesFrom rdf:resource="&fibo-sec-dbt-dbti;CallFeature"/>
							</owl:Restriction>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&fibo-sec-dbt-dbti;hasPutFeature"/>
								<owl:someValuesFrom rdf:resource="&fibo-sec-dbt-dbti;PutFeature"/>
							</owl:Restriction>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdf:type>
		<skos:editorialNote>Should this also only classify contracts that are convertible? Does this mean an additional restriction? Does it really apply to any sort of loan?</skos:editorialNote>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&fibo-actus-acv;ACTUSContractType-CreditDefaultSwap">
		<rdf:type>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-doc;refersTo"/>
				<owl:someValuesFrom rdf:resource="&fibo-der-cr-cds;CreditDefaultSwap"/>
			</owl:Restriction>
		</rdf:type>
		<skos:editorialNote>Is this really limited to CDS, or should it apply to anything (or maybe any derivative) where one of the parties to an underlying contract that triggers payment defaults?</skos:editorialNote>
	</owl:NamedIndividual>
	
