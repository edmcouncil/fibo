		<fibo-be-oac-opty:hasOwnedEntity rdf:resource="&fibo-fbc-fct-cra;DTC-US-NY"/>
		<fibo-be-oac-opty:hasOwningEntity rdf:resource="&fibo-fbc-fct-cra;DTCC-US-DE"/>
		<fibo-fnd-agr-ctr:isQualifiedBy rdf:resource="&fibo-be-le-lei;GenerallyAcceptedAccountingPrinciples"/>
	</owl:NamedIndividual>
	
